# =============================================================================
# FL3_V2 Docker Build Exclusions
# IMPORTANT: Review and update when adding new directories/files
# =============================================================================

# Git
.git
.gitignore

# Python bytecode
__pycache__
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
dist/
build/
*.egg

# Virtual environments
venv/
env/
.env
.env.*

# IDE
.vscode/
.idea/
*.swp
*.swo

# Testing
.pytest_cache/
.coverage
htmlcov/

# =============================================================================
# LOCAL DATA - These are the big ones!
# =============================================================================
polygon_data/
backups/
archive/
temp/
context/
.claude/
.tmp/

# Data files (CSV, compressed, etc.)
*.csv
*.csv.gz
*.parquet
*.h5
*.hdf5

# Windows artifacts
nul
*.bat

# =============================================================================
# DOCUMENTATION (not needed in container)
# =============================================================================
docs/
*.md
*.docx
*.pdf
*.txt
!requirements.txt

# JSON data files (PRD, config backups)
prd*.json

# =============================================================================
# ROOT-LEVEL SCRIPTS (dev/analysis - not needed in production)
# These are ad-hoc scripts that shouldn't be in the container.
# Production code lives in: adapters/, analysis/, firehose/, paper_trading/,
#                          phase_detectors/, scripts/, sources/, tracking/, uoa/, utils/
# =============================================================================

# Analysis scripts (root-level only — leading / prevents matching in subdirs)
/aaoi_*.py
/accumulation_analysis.py
/analyze_*.py
/deep_*.py
/enhanced_*.py
/projection_analysis.py
/quick_analysis.py
/timing_analysis.py

# Backtest scripts
/backtest_*.py
/e2e_backtest*.py
/e2e_label_outcomes.py
/label_backtest_outcomes.py
/multi_day_backtest.py
/realistic_backtest.py
/strategy_*.py
/ta_validation.py

# Check/debug scripts
/check_*.py
/verify_*.py

# Download scripts
/download_*.py
/explore_*.py
/polygon_*.py

# Test scripts (root level)
/test_*.py

# Fix scripts
/fix_*.py

# Other root scripts not needed in production
start_paper_trading.py

# =============================================================================
# NON-PRODUCTION DIRECTORIES
# =============================================================================
backtest_results/
deploy/
sql/
.pytest_cache/

